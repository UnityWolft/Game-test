<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3" data-tags="">Iniciar Sesión</td></tr>
</thead>
<tbody>
<tr><td>open</td><td>https://game-plataform.gamer.gd/index.php<datalist><option>https://game-plataform.gamer.gd/index.php</option></datalist></td><td></td></tr>
<tr><td>click</td><td>link=Login<datalist><option>link=Login</option><option>xpath=//a[contains(text(),'Login')]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Biblioteca'])[1]/following::a[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Tienda'])[1]/following::a[2]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Registro'])[1]/preceding::a[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Bienvenido a MiniSteam'])[1]/preceding::a[2]</option><option>xpath=//*/text()[normalize-space(.)='Login']/parent::*</option><option>xpath=//a[contains(@href, '/login.php')]</option><option>xpath=//a[4]</option></datalist></td><td></td></tr>
<tr><td>open</td><td>https://game-plataform.gamer.gd/login.php<datalist><option>https://game-plataform.gamer.gd/login.php</option></datalist></td><td></td></tr>
<tr><td>click</td><td>id=correo<datalist><option>id=correo</option><option>xpath=//input[@id='correo']</option><option>xpath=//form[@id='formLogin']/input</option><option>xpath=//input</option><option>css=#correo</option></datalist></td><td></td></tr>
<tr><td>type</td><td>id=correo<datalist><option>id=correo</option><option>xpath=//input[@id='correo']</option><option>xpath=//form[@id='formLogin']/input</option><option>xpath=//input</option><option>css=#correo</option></datalist></td><td>oscarperezme12@gmail.com</td></tr>
<tr><td>click</td><td>id=password<datalist><option>id=password</option><option>xpath=//input[@id='password']</option><option>xpath=//form[@id='formLogin']/input[2]</option><option>xpath=//input[2]</option><option>css=#password</option></datalist></td><td></td></tr>
<tr><td>type</td><td>id=password<datalist><option>id=password</option><option>xpath=//input[@id='password']</option><option>xpath=//form[@id='formLogin']/input[2]</option><option>xpath=//input[2]</option><option>css=#password</option></datalist></td><td>123456789</td></tr>
<tr><td>click</td><td>xpath=//form[@id='formLogin']/button<datalist><option>xpath=//form[@id='formLogin']/button</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Iniciar sesión'])[1]/following::button[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Registro'])[1]/following::button[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Katalon Recorder is recording ...'])[1]/preceding::button[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Stop'])[1]/preceding::button[1]</option><option>xpath=//*/text()[normalize-space(.)='Entrar']/parent::*</option><option>xpath=//button</option><option>css=button.btn.btn-primary</option></datalist></td><td></td></tr>
<tr><td>open</td><td>https://game-plataform.gamer.gd/index.php<datalist><option>https://game-plataform.gamer.gd/index.php</option></datalist></td><td></td></tr>
<tr><td>click</td><td>link=Salir<datalist><option>link=Salir</option><option>xpath=//a[contains(text(),'Salir')]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Biblioteca'])[1]/following::a[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Tienda'])[1]/following::a[2]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Panel Admin'])[1]/preceding::a[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Bienvenido a MiniSteam'])[1]/preceding::a[2]</option><option>xpath=//*/text()[normalize-space(.)='Salir']/parent::*</option><option>xpath=//a[contains(@href, '/logout.php')]</option><option>xpath=//a[4]</option></datalist></td><td></td></tr>
</tbody></table>
